[req]
default_bits = 4096
prompt = no
distinguished_name = dn
x509_extensions = v3_req

[dn]
CN = devstack.local

[v3_req]
subjectAltName = @alt_names
keyUsage = keyEncipherment, dataEncipherment
extendedKeyUsage = serverAuth

[alt_names]
DNS.1 = jenkins.local
DNS.2 = registry.local
DNS.3 = auth.local
DNS.4 = localhost
IP.1  = 127.0.0.1
